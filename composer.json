{
    "name": "jdanielcmedina/lapa",
    "description": "A minimalist PHP framework for building REST APIs and web applications",
    "type": "library",
    "keywords": [
        "framework",
        "php",
        "rest",
        "api"
    ],
    "homepage": "https://github.com/jdanielcmedina/lapa",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Medina",
            "email": "jdanielcmedina@gmail.com",
            "homepage": "https://github.com/jdanielcmedina",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.4",
        "catfan/medoo": "^2.1",
        "phpmailer/phpmailer": "^6.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Lapa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
