{
    "name": "jdanielcmedina/lapa",
    "description": "A minimalist PHP framework for building REST APIs and web applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Medina",
            "email": "jdanielcmedina@gmail.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "catfan/medoo": "^2.1",
        "phpmailer/phpmailer": "^6.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "classmap": [
            "src/"
        ],
        "psr-4": {
            "Lapa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable"
}
